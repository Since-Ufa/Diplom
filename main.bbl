      \field{internalsortvolume}{10}
      \field{issn}{2050-750X}
      \field{journaltitle}{Journal of Materials Chemistry B}
      \field{title}{A highly stable copper nano cluster on nitrogen-doped graphene quantum dots for the simultaneous electrochemical sensing of dopamine, serotonin, and nicotine: a possible addiction scrutinizing strategy}
